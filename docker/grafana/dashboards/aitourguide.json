{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Логи приложения",
      "url": "/d/aitourguide-logs",
      "type": "link",
      "icon": "external link",
      "tooltip": "Открыть dashboard с логами (Loki)",
      "targetBlank": false
    }
  ],
  "panels": [

    { "id": 100, "type": "row", "title": "📊 Обзор", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },

    {
      "id": 1, "type": "stat", "title": "Всего запросов",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background", "graphMode": "area", "textMode": "auto"
      },
      "fieldConfig": { "defaults": {
        "color": { "mode": "fixed", "fixedColor": "blue" },
        "unit": "short"
      }},
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(aitourguide_requests_total)", "legendFormat": "Всего", "refId": "A" }]
    },

    {
      "id": 2, "type": "stat", "title": "Успешных",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background", "graphMode": "area", "textMode": "auto"
      },
      "fieldConfig": { "defaults": {
        "color": { "mode": "fixed", "fixedColor": "green" },
        "unit": "short"
      }},
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(aitourguide_requests_total{status=\"success\"})", "legendFormat": "Успешных", "refId": "A" }]
    },

    {
      "id": 3, "type": "stat", "title": "Ошибок",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background", "graphMode": "area", "textMode": "auto"
      },
      "fieldConfig": { "defaults": {
        "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 1 },
          { "color": "red", "value": 10 }
        ]},
        "unit": "short"
      }},
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(aitourguide_requests_total{status=\"error\"})", "legendFormat": "Ошибок", "refId": "A" }]
    },

    {
      "id": 4, "type": "stat", "title": "Не распознано",
      "description": "Запросы где confidence < threshold — объект не найден в индексе",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background", "graphMode": "area", "textMode": "auto"
      },
      "fieldConfig": { "defaults": {
        "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 1 },
          { "color": "red", "value": 5 }
        ]},
        "unit": "short"
      }},
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "aitourguide_unknown_total", "legendFormat": "Unknown", "refId": "A" }]
    },

    {
      "id": 5, "type": "stat", "title": "Error rate",
      "description": "Доля ошибок за последние 5 минут",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background", "graphMode": "none", "textMode": "auto"
      },
      "fieldConfig": { "defaults": {
        "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 0.05 },
          { "color": "red", "value": 0.2 }
        ]},
        "unit": "percentunit", "min": 0, "max": 1, "noValue": "0%"
      }},
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(rate(aitourguide_requests_total{status=\"error\"}[5m])) / clamp_min(sum(rate(aitourguide_requests_total[5m])), 1)",
        "legendFormat": "Error rate", "refId": "A" }]
    },

    {
      "id": 6, "type": "stat", "title": "Объектов в индексе",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background", "graphMode": "none", "textMode": "auto"
      },
      "fieldConfig": { "defaults": {
        "color": { "mode": "fixed", "fixedColor": "blue" },
        "unit": "short"
      }},
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "aitourguide_index_size", "legendFormat": "Объектов", "refId": "A" }]
    },

    { "id": 101, "type": "row", "title": "📈 Трафик и качество", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 } },

    {
      "id": 7, "type": "timeseries", "title": "RPS",
      "description": "Запросов в секунду: успешные и ошибки",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": { "defaults": {
        "unit": "reqps",
        "custom": { "lineWidth": 2, "fillOpacity": 10 }
      }},
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(aitourguide_requests_total{status=\"success\"}[$__rate_interval]))",
          "legendFormat": "success", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(aitourguide_requests_total{status=\"error\"}[$__rate_interval]))",
          "legendFormat": "error", "refId": "B" }
      ]
    },

    {
      "id": 8, "type": "piechart", "title": "Источник ответа",
      "description": "retrieval — найдено в индексе; internet — потребовался поиск; fallback — поиск не дал результата",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 6 },
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "values": ["percent"] }
      },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "aitourguide_source_total", "legendFormat": "{{source}}", "refId": "A" }]
    },

    {
      "id": 9, "type": "timeseries", "title": "Confidence (p50 / p75)",
      "description": "Медианная уверенность модели. Если p50 < 0.5 — модель часто не уверена в распознавании",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 6 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": { "defaults": {
        "unit": "percentunit", "min": 0, "max": 1,
        "custom": { "lineWidth": 2, "fillOpacity": 10 },
        "noValue": "нет данных",
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "red", "value": null },
          { "color": "yellow", "value": 0.5 },
          { "color": "green", "value": 0.75 }
        ]}
      }},
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, rate(aitourguide_confidence_bucket[$__rate_interval]))",
          "legendFormat": "p50 (медиана)", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.75, rate(aitourguide_confidence_bucket[$__rate_interval]))",
          "legendFormat": "p75", "refId": "B" }
      ]
    },

    { "id": 102, "type": "row", "title": "⏱ Latency", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 } },

    {
      "id": 10, "type": "timeseries", "title": "Полное время запроса (p50 / p95 / p99)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": { "defaults": {
        "unit": "s",
        "custom": { "lineWidth": 2, "fillOpacity": 5 }
      }},
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum(rate(aitourguide_total_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(aitourguide_total_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p95", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum(rate(aitourguide_total_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p99", "refId": "C" }
      ]
    },

    {
      "id": 11, "type": "timeseries", "title": "Latency по этапам (p95)",
      "description": "Retrieval < 0.5с; VLM — самый долгий этап; internet search — только при низком confidence",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": { "defaults": {
        "unit": "s",
        "custom": { "lineWidth": 2, "fillOpacity": 5 }
      }},
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(aitourguide_retrieval_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "retrieval", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(aitourguide_vlm_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "VLM reranking", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(aitourguide_internet_search_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "internet search", "refId": "C" }
      ]
    }

  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["aitourguide", "ml", "fastapi"],
  "templating": {
    "list": [
      {
        "current": {}, "hide": 0, "includeAll": false,
        "name": "DS_PROMETHEUS", "options": [],
        "query": "prometheus", "refresh": 1, "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "AI Tour Guide",
  "uid": "aitourguide-main",
  "version": 5
}
