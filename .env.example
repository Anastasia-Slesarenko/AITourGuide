# ============================================================
# AI Tour Guide — конфигурация для VM (production)
#
# Скопируй в .env и заполни обязательные поля:
#   cp .env.example .env
# ============================================================

# ========================================
# S3 / DATA PATHS (VM-специфичные)
# ========================================
# Точка монтирования s3fs-бакета на хосте VM.
# Структура бакета:
#   landmarks/                       — изображения галереи (плоско: photo.jpg)
#   dataset/index/siglip/            — FAISS-индекс
#   models/qwen2-vl-2b-r16/          — VLM модель для vLLM
#   models/siglip-base-patch16-224/  — SigLIP модель
S3_MOUNT=/mnt/s3-aitourguide

# Директория для логов (локальная на хосте)
LOG_DIR=./logs

# ========================================
# YANDEX CLOUD API CREDENTIALS (обязательно)
# ========================================
# Нужны для интернет-поиска через Yandex Image Search
# Получить: https://cloud.yandex.ru/ → API-ключи
YC_FOLDER_ID=your_yandex_cloud_folder_id_here
YC_API_KEY=your_yandex_cloud_api_key_here

# ========================================
# MODEL PATHS
# ========================================
# Путь к SigLIP FAISS-индексу (внутри контейнера)
INDEX_DIR=/data/index/siglip

# Локальный путь к SigLIP модели (внутри контейнера)
SIGLIP_MODEL_PATH=/data/models/siglip-base-patch16-224

# Базовая директория изображений галереи (внутри контейнера).
# image_path в gallery_metadata.json — просто имя файла (photo.jpg),
# полный путь = IMAGES_BASE_DIR/photo.jpg
IMAGES_BASE_DIR=/data/images

# ========================================
# DEVICE CONFIGURATION
# ========================================
# SigLIP работает на CPU (vLLM использует GPU отдельно)
DEVICE=cpu

# ========================================
# SERVER CONFIGURATION
# ========================================
HOST=0.0.0.0
PORT=8000
API_PORT=8000

# Enable auto-reload (только для разработки)
RELOAD=false

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_CALLS=10
RATE_LIMIT_PERIOD=60

# ========================================
# TIMEOUTS AND LIMITS
# ========================================
PREDICT_TIMEOUT=90
MAX_FILE_SIZE_MB=10

# ========================================
# CORS CONFIGURATION
# ========================================
CORS_ORIGINS=["*"]
# false: публичный API без cookie/сессий; wildcard "*" + credentials невалиден по CORS
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# ========================================
# RAG CONFIGURATION
# ========================================
# Количество кандидатов из FAISS
TOP_K_RETRIEVAL=10

# Порог по сырому p_yes: accept/reject (known/unknown) и запуск интернет-поиска.
# Дефолт задан в коде (DEFAULT_CONFIDENCE_THRESHOLD в src/core/config.py) —
# строку можно не задавать, значение подхватится оттуда.
CONFIDENCE_THRESHOLD=0.472656

# Включить интернет-поиск при низкой уверенности
ENABLE_INTERNET_SEARCH=true

# ========================================
# LOGGING CONFIGURATION
# ========================================
LOG_LEVEL=INFO
# json — для продакшена, text — для разработки
LOG_FORMAT=json
LOG_FILE=
