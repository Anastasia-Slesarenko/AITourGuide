# ========================================
# YANDEX CLOUD API CREDENTIALS
# ========================================
# Required for internet search functionality
# Get your credentials at: https://cloud.yandex.ru/
YC_FOLDER_ID=your_yandex_cloud_folder_id_here
YC_API_KEY=your_yandex_cloud_api_key_here

# ========================================
# MODEL PATHS
# ========================================
# Paths to VLM model files (relative to project root)
MODEL_PATH=data/models/qwen2-vl-2b-r16/model-q5_k_m.gguf
MMPROJ_PATH=data/models/qwen2-vl-2b-r16/mmproj-model-f16.gguf

# Paths to RAG index and facts database
INDEX_PATH=artifacts/indexes/clip_index
FACTS_DB_PATH=artifacts/databases/facts_db.pkl

# ========================================
# DEVICE CONFIGURATION
# ========================================
# Device for model inference: "cuda" or "cpu"
DEVICE=cuda

# ========================================
# SERVER CONFIGURATION
# ========================================
# Host and port for the API server
HOST=0.0.0.0
PORT=8000

# Enable auto-reload for development (set to false in production)
RELOAD=false

# ========================================
# RATE LIMITING
# ========================================
# Maximum number of requests per period per IP
RATE_LIMIT_CALLS=10

# Time period in seconds for rate limiting
RATE_LIMIT_PERIOD=60

# ========================================
# TIMEOUTS AND LIMITS
# ========================================
# Maximum time (in seconds) for prediction request
PREDICT_TIMEOUT=90

# Maximum file size for uploaded images (in MB)
MAX_FILE_SIZE_MB=10

# ========================================
# CORS CONFIGURATION
# ========================================
# Allowed origins for CORS (comma-separated or ["*"] for all)
# Example: http://localhost:3000,https://example.com
CORS_ORIGINS=["*"]

# Allow credentials in CORS requests
CORS_ALLOW_CREDENTIALS=true

# Allowed HTTP methods for CORS
CORS_ALLOW_METHODS=["*"]

# Allowed headers for CORS
CORS_ALLOW_HEADERS=["*"]

# ========================================
# RAG CONFIGURATION
# ========================================
# Number of candidates to retrieve from FAISS index
TOP_K_RETRIEVAL=10

# Confidence threshold for triggering internet search
CONFIDENCE_THRESHOLD=0.78

# Maximum number of tokens to generate
MAX_NEW_TOKENS=256

# Enable internet search fallback for low confidence predictions
ENABLE_INTERNET_SEARCH=true

# ========================================
# LOGGING CONFIGURATION
# ========================================
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json or text
LOG_FORMAT=text

# Log file path (leave empty to disable file logging)
LOG_FILE=

# ========================================
# MONITORING (Optional)
# ========================================
# Enable Prometheus metrics endpoint
ENABLE_METRICS=false

# Prometheus metrics port
METRICS_PORT=9090

# ========================================
# DEVELOPMENT (Optional)
# ========================================
# Enable debug mode (more verbose logging, detailed errors)
DEBUG=false

# Enable profiling (performance analysis)
ENABLE_PROFILING=false
